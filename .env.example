# ============================================================
# NexusNow.ai RAG Chatbot — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# OpenAI
OPENAI_API_KEY=sk-proj-your-openai-api-key-here

# Gmail SMTP (use App Password, NOT your real password)
GMAIL_USER=nexusnow2026@gmail.com
GMAIL_PASS=xxxx xxxx xxxx xxxx

# Admin email that receives demo requests
ADMIN_EMAIL=nexusnow2026@gmail.com

# Server
PORT=3000

# Crawler — comma-separated URLs to crawl
CRAWL_URLS=https://nexusnow.ai,https://nexusnow.ai/about,https://nexusnow.ai/services,https://nexusnow.ai/pricing,https://nexusnow.ai/contact

# RAG settings
CHUNK_SIZE=800
CHUNK_OVERLAP=150
TOP_K_RESULTS=5
